{
  "name": "innergy-fls-coach",
  "version": "0.1.0",
  "private": true,
  "description": "Innergy — Full-Spectrum Leadership Coach (V1 MVP). Multi-tenant WhatsApp diagnostic + admin dashboard.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "worker:abandonment": "tsx src/workers/abandonment.ts",
    "worker:notifications": "tsx src/workers/notifications.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@prisma/client": "^6.1.0",
    "@types/qrcode": "^1.5.6",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",
    "next": "^15.1.3",
    "next-auth": "^4.24.11",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
