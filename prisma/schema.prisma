generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  whatsappNumber   String?             @unique
  whatsappMode     WhatsAppRoutingMode @default(shared)
  triggerPayload   String?             @unique
  logoUrl          String?
  primaryColor     String?
  secondaryColor   String?
  linkedinUrl      String?
  closingMessage   String?
  status           TenantStatus        @default(active)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  events           Event[]
  featureFlags     FeatureFlag[]
  messageTemplates MessageTemplate[]
  notifications    Notification[]
  results          Result[]
  sessions         Session[]
  coaches          TenantCoach[]
  instruments      TenantInstrument[]
  users            User[]

  @@index([slug])
}

model Coach {
  id                  String              @id @default(cuid())
  name                String
  bookingUrl          String
  notificationChannel NotificationChannel @default(email)
  notificationAddress String
  linkedinUrl         String?
  createdAt           DateTime            @default(now())
  notifications       Notification[]
  tenants             TenantCoach[]
}

model TenantCoach {
  tenantId  String
  coachId   String
  isPrimary Boolean @default(true)
  coach     Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, coachId])
}

model FeatureFlag {
  id       String @id @default(cuid())
  tenantId String
  key      String
  value    String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model Dimension {
  id             String          @id @default(cuid())
  name           String          @unique
  description    String?
  internalTag    String?
  dimensionBands DimensionBand[]
  sections       Section[]
}

model Instrument {
  id               String              @id @default(cuid())
  name             String              @unique
  description      String?
  currentVersionId String?             @unique
  currentVersion   InstrumentVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  versions         InstrumentVersion[] @relation("InstrumentVersions")
}

model InstrumentVersion {
  id                String             @id @default(cuid())
  instrumentId      String
  versionNumber     Int
  publishedAt       DateTime?
  publishedBy       String?
  metadata          Json
  dimensionBands    DimensionBand[]
  asCurrentOf       Instrument?        @relation("CurrentVersion")
  instrument        Instrument         @relation("InstrumentVersions", fields: [instrumentId], references: [id], onDelete: Cascade)
  overallBands      OverallBand[]
  results           Result[]
  sections          Section[]
  sessions          Session[]
  tenantInstruments TenantInstrument[]

  @@unique([instrumentId, versionNumber])
}

model TenantInstrument {
  tenantId            String
  instrumentVersionId String
  effectiveFrom       DateTime          @default(now())
  instrumentVersion   InstrumentVersion @relation(fields: [instrumentVersionId], references: [id], onDelete: Cascade)
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, instrumentVersionId])
}

model Section {
  id                  String            @id @default(cuid())
  instrumentVersionId String
  dimensionId         String
  displayOrder        Int
  introTemplateKey    String
  questions           Question[]
  dimension           Dimension         @relation(fields: [dimensionId], references: [id])
  instrumentVersion   InstrumentVersion @relation(fields: [instrumentVersionId], references: [id], onDelete: Cascade)

  @@unique([instrumentVersionId, displayOrder])
}

model Question {
  id           String   @id @default(cuid())
  sectionId    String
  stem         String
  displayOrder Int
  internalTag  String?
  answers      Answer[]
  options      Option[]
  section      Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, displayOrder])
}

model Option {
  id           String      @id @default(cuid())
  questionId   String
  label        OptionLabel
  text         String
  score        Int
  displayOrder Int
  internalTag  String?
  answers      Answer[]
  question     Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, label])
  @@unique([questionId, displayOrder])
}

model DimensionBand {
  id                     String            @id @default(cuid())
  instrumentVersionId    String
  dimensionId            String
  minScore               Int
  maxScore               Int
  bandLabel              String
  interpretationTemplate String
  bandColorHex           String?
  dimension              Dimension         @relation(fields: [dimensionId], references: [id])
  instrumentVersion      InstrumentVersion @relation(fields: [instrumentVersionId], references: [id], onDelete: Cascade)

  @@index([instrumentVersionId, dimensionId])
}

model OverallBand {
  id                     String            @id @default(cuid())
  instrumentVersionId    String
  minScore               Int
  maxScore               Int
  bandLabel              String
  interpretationTemplate String
  instrumentVersion      InstrumentVersion @relation(fields: [instrumentVersionId], references: [id], onDelete: Cascade)

  @@index([instrumentVersionId])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  key       String
  tenantId  String?
  locale    String   @default("en")
  body      String
  updatedAt DateTime @updatedAt
  updatedBy String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([key, tenantId, locale])
  @@index([key, locale])
}

model LlmPromptTemplate {
  id                String   @id @default(cuid())
  key               String
  version           Int
  body              String
  responseSchema    Json
  maxNarrativeChars Int      @default(350)
  isActive          Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  @@unique([key, version])
  @@index([key, isActive])
}

model User {
  id                String         @id @default(cuid())
  tenantId          String
  whatsappPhoneHash String
  firstName         String?
  organisation      String?
  voiceMode         VoiceMode      @default(off)
  createdAt         DateTime       @default(now())
  lastSeenAt        DateTime       @default(now())
  deletedAt         DateTime?
  email             String?
  events            Event[]
  notifications     Notification[]
  results           Result[]
  sessions          Session[]
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, whatsappPhoneHash])
}

model Session {
  id                  String            @id @default(cuid())
  tenantId            String
  userId              String
  instrumentVersionId String
  status              SessionStatus     @default(in_progress)
  fsmState            Json
  whatsappPhone       String?
  startedAt           DateTime          @default(now())
  lastMessageAt       DateTime          @default(now())
  completedAt         DateTime?
  abandonedAt         DateTime?
  answers             Answer[]
  events              Event[]
  notifications       Notification[]
  result              Result?
  instrumentVersion   InstrumentVersion @relation(fields: [instrumentVersionId], references: [id])
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([lastMessageAt])
}

model Answer {
  id              String    @id @default(cuid())
  sessionId       String
  questionId      String
  optionId        String
  rawInput        String
  rawInputType    InputType @default(text)
  voiceTranscript String?
  answeredAt      DateTime  @default(now())
  option          Option    @relation(fields: [optionId], references: [id])
  question        Question  @relation(fields: [questionId], references: [id])
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
}

model Result {
  id                  String             @id @default(cuid())
  sessionId           String             @unique
  tenantId            String
  userId              String
  instrumentVersionId String
  cognitiveScore      Int
  cognitiveBand       String
  relationalScore     Int
  relationalBand      String
  innerScore          Int
  innerBand           String
  overallScore        Int
  overallBand         String
  lowestDimensionId   String
  interpretationMode  InterpretationMode
  interpretationJson  Json
  generatedAt         DateTime           @default(now())
  instrumentVersion   InstrumentVersion  @relation(fields: [instrumentVersionId], references: [id])
  session             Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, generatedAt])
}

model Notification {
  id        String              @id @default(cuid())
  tenantId  String
  coachId   String?
  userId    String?
  sessionId String?
  type      NotificationType
  channel   NotificationChannel
  payload   Json
  status    NotificationStatus  @default(pending)
  attempts  Int                 @default(0)
  lastError String?
  createdAt DateTime            @default(now())
  sentAt    DateTime?
  coach     Coach?              @relation(fields: [coachId], references: [id])
  session   Session?            @relation(fields: [sessionId], references: [id])
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?               @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([tenantId, createdAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String
  entity      String
  entityId    String
  action      AuditAction
  before      Json?
  after       Json?
  at          DateTime    @default(now())

  @@index([entity, entityId])
  @@index([at])
}

model Event {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  sessionId  String?
  eventType  String
  properties Json
  at         DateTime @default(now())
  session    Session? @relation(fields: [sessionId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, eventType, at])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  role         AdminRole
  tenantId     String?
  passwordHash String?
  mfaEnabled   Boolean   @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
}

enum WhatsAppRoutingMode {
  dedicated
  shared
}

enum TenantStatus {
  active
  disabled
}

enum NotificationChannel {
  email
  whatsapp
}

enum OptionLabel {
  A
  B
  C
  D
}

enum VoiceMode {
  off
  on
}

enum SessionStatus {
  in_progress
  completed
  abandoned
  escalated
}

enum InputType {
  text
  voice
}

enum InterpretationMode {
  template
  llm
}

enum NotificationType {
  coaching_interest
  escalation
  digest
  user_report
}

enum NotificationStatus {
  pending
  sent
  failed
}

enum AuditAction {
  create
  update
  delete
  publish
}

enum AdminRole {
  super_admin
  tenant_admin
  coach
}
